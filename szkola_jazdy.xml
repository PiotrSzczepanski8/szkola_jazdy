<?xml version="1.0" encoding="UTF-8"?>
<dbd_document>
  <version>4.1</version>
  <table>
    <name>uzytkownicy</name>
    <field>
      <name>id</name>
      <type>INT</type>
      <primaryKey>true</primaryKey>
      <autoIncrement>true</autoIncrement>
      <notnull>true</notnull>
    </field>
    <field>
      <name>nazwa_uzytkownika</name>
      <type>VARCHAR(50)</type>
      <notnull>true</notnull>
      <unique>true</unique>
    </field>
    <field>
      <name>haslo_hash</name>
      <type>VARCHAR(255)</type>
      <notnull>true</notnull>
    </field>
    <field>
      <name>email</name>
      <type>VARCHAR(100)</type>
      <notnull>true</notnull>
      <unique>true</unique>
    </field>
    <field>
      <name>typ_uzytkownika</name>
      <type>ENUM('kursant', 'instruktor', 'admin')</type>
      <notnull>true</notnull>
    </field>
    <field>
      <name>data_utworzenia</name>
      <type>TIMESTAMP</type>
      <default>CURRENT_TIMESTAMP</default>
    </field>
  </table>

  <table>
    <name>kursanci</name>
    <field>
      <name>uzytkownik_id</name>
      <type>INT</type>
      <primaryKey>true</primaryKey>
      <foreignKey>true</foreignKey>
      <references>uzytkownicy(id)</references>
      <onDelete>CASCADE</onDelete>
    </field>
    <field>
      <name>imie_nazwisko</name>
      <type>VARCHAR(100)</type>
      <notnull>true</notnull>
    </field>
    <field>
      <name>data_urodzenia</name>
      <type>DATE</type>
      <notnull>true</notnull>
    </field>
    <field>
      <name>telefon</name>
      <type>VARCHAR(20)</type>
    </field>
    <field>
      <name>adres</name>
      <type>VARCHAR(255)</type>
    </field>
    <field>
      <name>kategoria_prawa_jazdy</name>
      <type>ENUM('A', 'B', 'C', 'D', 'E')</type>
      <notnull>true</notnull>
    </field>
  </table>

  <table>
    <name>instruktorzy</name>
    <field>
      <name>uzytkownik_id</name>
      <type>INT</type>
      <primaryKey>true</primaryKey>
      <foreignKey>true</foreignKey>
      <references>uzytkownicy(id)</references>
      <onDelete>CASCADE</onDelete>
    </field>
    <field>
      <name>imie_nazwisko</name>
      <type>VARCHAR(100)</type>
      <notnull>true</notnull>
    </field>
    <field>
      <name>data_zatrudnienia</name>
      <type>DATE</type>
      <notnull>true</notnull>
    </field>
    <field>
      <name>telefon</name>
      <type>VARCHAR(20)</type>
    </field>
    <field>
      <name>adres</name>
      <type>VARCHAR(255)</type>
    </field>
  </table>

  <table>
    <name>lekcje</name>
    <field>
      <name>id</name>
      <type>INT</type>
      <primaryKey>true</primaryKey>
      <autoIncrement>true</autoIncrement>
    </field>
    <field>
      <name>kursant_id</name>
      <type>INT</type>
      <foreignKey>true</foreignKey>
      <references>kursanci(uzytkownik_id)</references>
      <onDelete>CASCADE</onDelete>
    </field>
    <field>
      <name>instruktor_id</name>
      <type>INT</type>
      <foreignKey>true</foreignKey>
      <references>instruktorzy(uzytkownik_id)</references>
      <onDelete>CASCADE</onDelete>
    </field>
    <field>
      <name>data_lekcji</name>
      <type>TIMESTAMP</type>
      <notnull>true</notnull>
    </field>
    <field>
      <name>czas_trwania_minuty</name>
      <type>INT</type>
      <notnull>true</notnull>
    </field>
  </table>

  <table>
    <name>logi_admin</name>
    <field>
      <name>id</name>
      <type>INT</type>
      <primaryKey>true</primaryKey>
      <autoIncrement>true</autoIncrement>
    </field>
    <field>
      <name>admin_id</name>
      <type>INT</type>
      <foreignKey>true</foreignKey>
      <references>uzytkownicy(id)</references>
      <onDelete>CASCADE</onDelete>
    </field>
    <field>
      <name>akcja</name>
      <type>VARCHAR(255)</type>
      <notnull>true</notnull>
    </field>
    <field>
      <name>znacznik_czasu</name>
      <type>TIMESTAMP</type>
      <default>CURRENT_TIMESTAMP</default>
    </field>
  </table>
</dbd_document>
